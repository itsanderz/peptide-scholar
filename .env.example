# PeptideScholar Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# ─── Analytics ───────────────────────────────────────────────────────────────

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Plausible Analytics domain
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─── Advertising ─────────────────────────────────────────────────────────────

# Google AdSense publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT=

# ─── Email / Lead Capture ─────────────────────────────────────────────────────

# Resend API key for transactional email (subscribe, lead notifications)
RESEND_API_KEY=

# ─── Provider Lead Routing (Phase 2) ─────────────────────────────────────────

# Webhook URL that receives ProviderCrmPayload JSON on every qualifying lead.
# See docs/CRM_PAYLOAD_CONTRACT.md for the full payload schema.
# If unset, leads are logged to console only (no outbound delivery).
PROVIDER_LEAD_WEBHOOK_URL=

# Optional shared secret sent as X-Lead-Secret header on every webhook call.
# The receiving endpoint should verify this value before processing the payload.
PROVIDER_LEAD_WEBHOOK_SECRET=

# ─── Partner Status Callbacks (Phase 2 — P2.3) ───────────────────────────────

# Shared secret that partner systems must send as X-Partner-Secret header
# when POSTing outcome updates to /api/leads/provider/status.
# If unset, the status endpoint will reject all incoming callbacks.
PROVIDER_STATUS_CALLBACK_SECRET=
